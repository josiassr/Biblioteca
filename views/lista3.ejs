<html>
  <head>
    <title>Biblioteca</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  </head>
  <body>
    <div class="jumbotron text-center" style="margin-bottom:0">
      <h1>Livros</h1>
    </div>

    <nav class="navbar navbar-expand-sm bg-dark navbar-dark" style="margin-bottom:20">
      <div class="collapse navbar-collapse justify-content-center" id="collapsibleNavbar">
          <ul class="navbar-nav">
          <li class="nav-item">
              <a class="nav-link" href="http://localhost:8000/1">Usuarios</a>
          </li>
          <li class="nav-item">
              <a class="nav-link" href="http://localhost:8000/3">Livros</a>
          </li>
          <li class="nav-item">
              <a class="nav-link" href="http://localhost:8000/2">Tipos de usuários</a>
          </li>
          <li class="nav-item">
              <a class="nav-link" href="http://localhost:8000/4">Categorias dos livros</a>
          </li>
          </ul>
      </div>
  </nav>

    <div class="container">

      <a href="/inserir3" class="btn btn-outline-primary" role="button" style="margin-bottom:20">Inserir Livros</a>
      <table class="table" style="margin-bottom:20">
        <thead>
          <tr class="table-dark text-dark">
            <th>Ação</th>
            <th>Id do livro</th>
            <th>Id do usuário</th>
            <th>Título</th>
            <th>Escritor</th>
            <th>Editora</th>
            <th>Ano de publicação</th>
            <th>Número de edição</th>
            <th>Número de páginas</th>
            <th>Id da categoria do livro</th>
            <th>Preço</th>
          </tr>
        </thead>
        <% livros.forEach((book, index) => { %>
        <tbody>
          <tr class="table-light">
            <td>
              <a href="atualizar3?id=<%= book.id %>">Atualizar</a>&nbsp;&nbsp;
              <a href="excluir3?id=<%= book.id %>">Excluir</a>
            </td>
            <td><%= book.id %></td>
            <td><%= book.usuario_id %></td>
            <td><%= book.titulo %></td>
            <td><%= book.escritor %></td>
            <td><%= book.editora %></td>
            <td><%= book.ano_publicacao %></td>
            <td><%= book.numero_edicao %></td>
            <td><%= book.paginas %></td>
            <td><%= book.categoria_id %></td>
            <td><%= book.preco %></td>
          </tr>
        </tbody>
        <% }) %>
      </table>
    </div>
    <div class="jumbotron text-center" style="margin-bottom:0"></div>
  </body>
</html>