<!DOCTYPE html>
<html lang="en">
<head>
  <title>Biblioteca dos Guri</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css">
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.3/umd/popper.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.1.3/js/bootstrap.min.js"></script>
  <script>
      function inicializar(){
          let over = document.getElementById("tex");
          over.style.textAlign = "center";
          over.style.color = "grey";
          over.style.marginTop = "50px";

          let usu = document.getElementById("usu");
          usu.style.marginTop = "50px";

          let liv = document.getElementById("liv");
          liv.style.marginTop = "50px";

          let cat = document.getElementById("cat");
          cat.style.marginTop = "50px";

          let tip = document.getElementById("tip");
          tip.style.marginTop = "50px";
      }

      window.addEventListener("load", inicializar);
  </script>
</head>
<body>
<div>
   <h2 id="tex">Biblioteca dos Guri</h2>
</div> <br>
<div class="container">
  <a href="http://localhost:8000/1">
    <button type="button" class="btn btn-outline-info btn-block" id="usu">Usuários</button>
  </a>
  <a href="http://localhost:8000/3">
    <button type="button" class="btn btn-outline-info btn-block" id="liv">Livros</button>
  </a>
  <a href="http://localhost:8000/2">
    <button type="button" class="btn btn-outline-info btn-block" id="cat">Categorias dos Livros</button>
  </a>
  <a href="http://localhost:8000/4">
    <button type="button" class="btn btn-outline-info btn-block" id="tip">Tipos de Usuários</button>
  </a>
</div>

</body>
</html>