<html>
    <head>
        <title>Biblioteca</title>
        <meta charset="UTF-8">
        <script language="javascript">
          function validarInformacoes(){
            var nome = document.getElementById('nome').value;
            var sobrenome = document.getElementById('sobrenome').value;

            if (nome == '') {
              alert('O campo Nome é obrigatório.');
              return false;
            } else if (nome == ' '){
              alert('O campo Nome é obrigatório.');
              return false;
            }

            if (sobrenome == '') {
              alert('O campo Sobrenome é obrigatório.');
              return false;
            } else if (sobrenome == ' ') {
              alert('O campo Sobrenome é obrigatório.');
              return false;
            }

            if (isNaN(tipo_usuario_id) == true) {
              alert('O campo Id do tipo de usuário dever ser numérico.');
              return false;
            }

            return true;
          }
        </script>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js"></script>
        <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
        <style>
          .nav justify-content-center{
              height: 50%;
          }
        </style>
    </head>
    <body>
      <div class="jumbotron text-center" style="margin-bottom:0">
        <h1>Atualização dos Usuários</h1>
      </div>
  
      <nav class="navbar navbar-expand-sm bg-dark navbar-dark" style="margin-bottom:20">
        <div class="collapse navbar-collapse justify-content-center" id="collapsibleNavbar">
            <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" href="http://localhost:8000/1">Usuarios</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="http://localhost:8000/3">Livros</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="http://localhost:8000/2">Tipos de usuários</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="http://localhost:8000/4">Categorias dos livros</a>
            </li>
            </ul>
        </div>
    </nav>
        
      <form action="salvar1" method="post" onsubmit="validarInformacoes()">
        <div class="container">
          <input type="hidden" name="id1" value= "<%= (usuarios.length > 0 ? usuarios[0].id:"") %>">
          
          <div class="form-group">
            <label for="nome">Nome:</label>
            <input type="text" class="form-control" required="required" name="nome" value="<%= (usuarios.length > 0 ? usuarios[0].nome:"") %>" id="nome">
          </div>

          <div class="form-group">
            <label for="sobrenome">Sobrenome:</label>
            <input type="text" class="form-control" required="required" name="sobrenome" value="<%= (usuarios.length > 0 ? usuarios[0].sobrenome:"") %>" id="sobrenome">
          </div>

          <div class="form-group">
            <label for="endereco">Endereço:</label>
            <input type="text" class="form-control" name="endereco" value="<%= (usuarios.length > 0 ? usuarios[0].endereco:"") %>" id="endereco">
          </div>

          <div class="form-group">
            <label for="cidade">Cidade:</label>
            <input type="text"  class="form-control" name="cidade" value="<%= (usuarios.length > 0 ? usuarios[0].cidade:"") %>" id="cidade">
          </div>

          <div class="form-group">
            <label for="sigla_estado">Estado:</label>
            <select name="sigla_estado" class="form-control" id="sigla_estado">
                <option value="" >Selecione seu Estado:</option>
                <option value="AC" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "AC") ? "selected":"") %>>Acre</option>
                <option value="AL" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "AL") ? "selected":"") %>>Alagoas</option>
                <option value="AP" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "AP") ? "selected":"") %>>Amapá</option>
                <option value="AM" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "AM") ? "selected":"") %>>Amazonas</option>
                <option value="BA" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "BA") ? "selected":"") %>>Bahia</option>
                <option value="CE" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "CE") ? "selected":"") %>>Ceará</option>
                <option value="DF" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "DF") ? "selected":"") %>>Distrito Federal</option>
                <option value="ES" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "ES") ? "selected":"") %>>Espirito Santo</option>
                <option value="GO" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "GO") ? "selected":"") %>>Goiás</option>
                <option value="MA" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "MA") ? "selected":"") %>>Maranhão</option>
                <option value="MS" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "MS") ? "selected":"") %>>Mato Grosso do Sul</option>
                <option value="MT" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "MT") ? "selected":"") %>>Mato Grosso</option>
                <option value="MG" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "MG") ? "selected":"") %>>Minas Gerais</option>
                <option value="PA" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "PA") ? "selected":"") %>>Pará</option>
                <option value="PB" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "PB") ? "selected":"") %>>Paraíba</option>
                <option value="PR" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "PR") ? "selected":"") %>>Paraná</option>
                <option value="PE" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "PE") ? "selected":"") %>>Pernambuco</option>
                <option value="PI" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "PI") ? "selected":"") %>>Piauí</option>
                <option value="RJ" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "RJ") ? "selected":"") %>>Rio de Janeiro</option>
                <option value="RN" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "RN") ? "selected":"") %>>Rio Grande do Norte</option>
                <option value="RS" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "RS") ? "selected":"") %>>Rio Grande do Sul</option>
                <option value="RO" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "RO") ? "selected":"") %>>Rondônia</option>
                <option value="RR" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "RR") ? "selected":"") %>>Roraima</option>
                <option value="SC" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "SC") ? "selected":"") %>>Santa Catarina</option>
                <option value="SP" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "SP") ? "selected":"") %>>São Paulo</option>
                <option value="SE" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "SE") ? "selected":"") %>>Sergipe</option>
                <option value="TO" <%= ((usuarios.length > 0 && usuarios[0].sigla_estado == "TO") ? "selected":"") %>>Tocantins</option>
            </select>
          </div>

          <div class="form-group">
            <label for="telefone">Telefone: EX: (11) 91111-1111</label>
            <input type="text" pattern="(\([0-9]{2}\))\s([9]{1})?([0-9]{4})-([0-9]{4})" required="required" class="form-control" name="telefone" value="<%= (usuarios.length > 0 ? usuarios[0].telefone:"") %>" id="telefone">
          </div>

          <div class="form-group">
            <label for="tipo_usuario_id">Id do tipo de usuário:</label>
            <input type="number" required="required" class="form-control" name="tipo_usuario_id" value="<%= (usuarios.length > 0 ? usuarios[0].tipo_usuario_id:"") %>" id="tipo_usuario_id">
          </div>

          </div>
          <div class="jumbotron text-center" style="margin-bottom:0">
            <input type="submit" class="btn btn-outline-primary" role="button" name="acao1" value="Atualizar">
            <input type="reset" class="btn btn-outline-primary" role="button" name="acao1" value="Cancelar">
          </div>
      </form>
    </body>
</html>